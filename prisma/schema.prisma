generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("tester")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  testCases    TestCase[]
  bugs         Bug[]
  assignedBugs Bug[]      @relation("AssignedBugs")
  activities   Activity[]
}

model TestCase {
  id             String   @id @default(uuid())
  title          String
  description    String
  steps          String
  expectedResult String
  actualResult   String?
  status         String   @default("pending")
  severity       String   @default("medium")
  priority       String   @default("medium")
  environment    String
  createdBy      String
  assignedTo     String?
  executedAt     DateTime?
  executedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user        User                  @relation(fields: [createdBy], references: [id])
  screenshots TestCaseScreenshot[]
  bugs        Bug[]
}

model Bug {
  id                String   @id @default(uuid())
  title             String
  description       String
  stepsToReproduce  String
  severity          String   @default("medium")
  status            String   @default("open")
  environment       String
  testCaseId        String?
  createdBy         String
  assignedTo        String?
  resolvedAt        DateTime?
  resolutionNotes   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  testCase   TestCase?     @relation(fields: [testCaseId], references: [id])
  creator    User          @relation(fields: [createdBy], references: [id])
  assignee   User?         @relation("AssignedBugs", fields: [assignedTo], references: [id])
  screenshots BugScreenshot[]
}

model TestCaseScreenshot {
  id         String   @id @default(uuid())
  url        String
  key        String   @unique
  testCaseId String
  createdAt  DateTime @default(now())
  
  testCase TestCase @relation(fields: [testCaseId], references: [id])
  
  @@index([testCaseId])
}

model BugScreenshot {
  id         String   @id @default(uuid())
  url        String
  key        String   @unique
  bugId      String
  createdAt  DateTime @default(now())
  
  bug Bug @relation(fields: [bugId], references: [id])
  
  @@index([bugId])
}

model Activity {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String
  details    Json?
  createdAt  DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([createdAt])
}